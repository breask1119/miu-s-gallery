---
// src/layouts/Layout.astro
/**
 * サイト全体の共通レイアウトコンポーネントです。
 * ViewTransitionsによるシームレスな画面遷移をサポートします。
 */
import { ViewTransitions } from 'astro:transitions';
import '../styles/app.scss';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="ja" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Tactile Maximalism & Bento Grid Gallery" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body class="bg-brand-dark text-gray-200 antialiased selection:bg-brand-neon selection:text-white">
    <slot />
  </body>
</html>
---
// src/pages/index.astro
import { ClientRouter } from 'astro:transitions';
import '../styles/app.scss';
import { getGalleryData } from '../lib/wp';
import SiteFooter from '../components/SiteFooter.astro';

const { siteInfo, sliders, models } = await getGalleryData();

const allArtworks = models.flatMap((model: any) => 
  model.artworks?.nodes?.map((art: any) => ({ ...art, model })) || []
);

const placeholderImg = "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=1200&auto=format&fit=crop";
const wpGraphqlUrl = import.meta.env.PUBLIC_WP_GRAPHQL_URL || '';

const secureUrl = (url: string) => {
  if (!url) return '';
  let httpsUrl = url.replace(/^http:\/\//i, 'https://');
  if (wpGraphqlUrl && !httpsUrl.includes('unsplash.com')) {
    try {
      const wpOrigin = new URL(wpGraphqlUrl).origin;
      const urlObj = new URL(httpsUrl);
      if (urlObj.origin !== wpOrigin) {
        urlObj.protocol = new URL(wpOrigin).protocol;
        urlObj.hostname = new URL(wpOrigin).hostname;
        urlObj.port = new URL(wpOrigin).port;
        return urlObj.toString();
      }
    } catch (e) {}
  }
  return httpsUrl;
};

const hexToRgba = (hex: string, alpha: number = 0.5) => {
  const validHex = hex && hex.trim() !== '' ? hex : '#F43F5E';
  const r = parseInt(validHex.slice(1, 3), 16);
  const g = parseInt(validHex.slice(3, 5), 16);
  const b = parseInt(validHex.slice(5, 7), 16);
  if (isNaN(r) || isNaN(g) || isNaN(b)) {
     return `rgba(244, 63, 94, ${alpha})`;
  }
  return `rgba(${r}, ${g}, ${b}, ${alpha})`;
};

const getValidColor = (color: string) => (color && color.trim() !== '') ? color : '#F43F5E';

const getTextColorClasses = (hex: string) => {
  const validHex = hex && hex.trim() !== '' ? hex : '#F43F5E';
  const r = parseInt(validHex.slice(1, 3), 16);
  const g = parseInt(validHex.slice(3, 5), 16);
  const b = parseInt(validHex.slice(5, 7), 16);
  
  if (isNaN(r) || isNaN(g) || isNaN(b)) {
     return { main: 'text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)]', sub: 'text-white/80 drop-shadow-[0_1px_2px_rgba(0,0,0,0.8)]' };
  }
  
  const yiq = ((r * 299) + (g * 587) + (b * 114)) / 1000;
  
  if (yiq >= 128) {
    return { main: 'text-[#0A0A0C] font-normal', sub: 'text-[#0A0A0C]/80 font-normal' };
  } else {
    return { main: 'text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)]', sub: 'text-white/80 drop-shadow-[0_1px_2px_rgba(0,0,0,0.8)]' };
  }
};

const globalBaseColor = models.length > 0 ? getValidColor(models[0].memberColor) : '#F43F5E';

const displaySliders = sliders && sliders.length > 0 
  ? sliders 
  : [{ featuredImage: { node: { sourceUrl: placeholderImg } }, title: 'Welcome' }];

const getVariationsArray = (art: any) => {
  const images = art.orderedImages;
  if (images && images.length > 0) {
    return images.map((img: any) => secureUrl(img.sourceUrl));
  }
  return [secureUrl(art.featuredImage?.node?.sourceUrl) || placeholderImg];
};
---

<html lang="ja" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Miu's Gallery | AI Girls Gallery</title>
    <ClientRouter />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300&family=Noto+Sans+JP:wght@300&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/css/splide.min.css" rel="stylesheet">
    
    <script define:vars={{ wpGraphqlUrl }}>
      window.WP_GRAPHQL_URL = wpGraphqlUrl;
    </script>
  </head>
  <body class="bg-[#050505] text-gray-200 antialiased selection:bg-[#F43F5E] selection:text-white overflow-hidden u-bg-noise font-light">
    
    <div id="custom-cursor" class="hidden lg:flex"><span id="cursor-text"></span></div>

    <!-- ▼ JSから動的に色を変えられるように、初期の背景色と文字色のクラスを外しました -->
    <div id="global-sidebar-tooltip" class="fixed z-[150] text-xs px-3 py-1.5 rounded-lg opacity-0 transition-opacity duration-200 pointer-events-none whitespace-nowrap shadow-xl border border-white/20 font-light tracking-wide -translate-y-1/2"></div>

    <main class="flex flex-col lg:flex-row h-[100dvh] w-full bg-transparent overflow-y-auto lg:overflow-hidden relative z-10">
      
      <section 
        class="w-full h-[70dvh] lg:h-[100dvh] lg:w-[70%] flex-none relative bg-black overflow-hidden group cursor-zoom-in touch-manipulation select-none shadow-2xl shrink-0 order-1"
        onclick="window.handleHeroInteraction(event)"
      >
        <div id="hero-slider-wrapper" class="w-full h-full absolute inset-0 transition-opacity duration-700 z-0">
          <div id="hero-slider" class="splide w-full h-full">
            <div class="splide__track w-full h-full">
              <ul class="splide__list w-full h-full">
                {displaySliders.map((slide: any) => {
                  const src = secureUrl(slide.featuredImage?.node?.sourceUrl) || placeholderImg;
                  const themeColor = slide.memberColor ? getValidColor(slide.memberColor) : globalBaseColor;
                  const bgColor = hexToRgba(themeColor, 0.6);
                  const borderColor = hexToRgba(themeColor, 0.3);

                  return (
                    <li class="splide__slide w-full h-full relative">
                      <img src={src} class="js-main-bg absolute inset-0 w-full h-full object-cover opacity-70 blur-[20px] pointer-events-none" referrerpolicy="no-referrer" />
                      <img src={src} fetchpriority="high" class="js-main-img absolute inset-0 w-full h-full object-contain z-10" referrerpolicy="no-referrer" />
                      
                      {slide.title && (
                        <div class="js-slide-title absolute bottom-8 right-6 lg:bottom-[120px] lg:right-12 z-20 pointer-events-none text-right">
                          <h2 
                            class="inline-block text-white text-lg lg:text-2xl font-light tracking-widest backdrop-blur-xl px-6 lg:px-8 py-3 lg:py-4 rounded-2xl shadow-[0_8px_32px_0_rgba(0,0,0,0.3)] drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)]"
                            style={`background-color: ${bgColor}; border: 1px solid ${borderColor};`}
                          >
                            {slide.title}
                          </h2>
                        </div>
                      )}
                    </li>
                  );
                })}
              </ul>
            </div>
          </div>
        </div>

        <div id="hero-static-wrapper" class="w-full h-full absolute inset-0 transition-opacity duration-700 opacity-0 hidden z-0">
          <img id="hero-static-bg" src="" class="absolute inset-0 w-full h-full object-cover opacity-70 blur-[20px] transition-opacity duration-500 pointer-events-none" referrerpolicy="no-referrer" />
          <img id="hero-static-img" src="" class="absolute inset-0 w-full h-full object-contain z-10 transition-all duration-700 ease-out" referrerpolicy="no-referrer" />
        </div>
        
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent opacity-100 pointer-events-none z-10 h-1/2 mt-auto"></div>
        
        <div class="absolute bottom-6 lg:bottom-[100px] left-0 p-6 lg:px-10 w-full pointer-events-none z-10">
          <h1 id="hero-title" class="text-4xl lg:text-6xl font-light tracking-tighter text-transparent bg-clip-text bg-gradient-to-br from-white to-gray-500 [text-shadow:_0_4px_20px_rgb(0_0_0_/_80%)] leading-tight transition-opacity duration-300" set:html={siteInfo.title}></h1>
          <div id="hero-bio" class="hidden mt-4 w-full pr-4 text-sm lg:text-base text-gray-200 font-light tracking-[0.1em] leading-relaxed [text-shadow:_0_2px_10px_rgb(0_0_0_/_100%)] opacity-0 transition-opacity duration-700"></div>
          <div id="hero-prompt" class="hidden mt-3 w-full pr-4 text-xs lg:text-sm text-gray-400 font-light tracking-wide leading-relaxed [text-shadow:_0_2px_10px_rgb(0_0_0_/_100%)] opacity-0 transition-opacity duration-700"></div>
        </div>
      </section>

      <section class="w-full lg:w-[30%] h-auto lg:h-[100dvh] relative flex bg-[#0A0A0C]/80 backdrop-blur-xl border-l border-white/5 order-2" id="right-panel-wrapper">
        
        <div class="flex-1 overflow-y-auto scroll-smooth p-5 lg:p-10 pb-28 lg:pb-[110px]" id="right-panel">
          
          <div id="view-categories" class="view-section active">
            <h2 class="text-xl lg:text-2xl font-light mb-6 text-white border-b border-white/10 pb-4 tracking-tight">Models & Characters</h2>
            <div class="grid grid-cols-2 gap-4 lg:gap-5">
              {models.map((model: any) => {
                const latestArtworkImg = secureUrl(model.artworks?.nodes?.[0]?.featuredImage?.node?.sourceUrl);
                const avatarSrc = secureUrl(model.modelAvatar?.node?.sourceUrl) || placeholderImg;
                const displayImage = latestArtworkImg || avatarSrc;
                const modelColor = getValidColor(model.memberColor);
                
                const cardTextBgColor = hexToRgba(modelColor, 0.35);
                const cardTextBorderColor = hexToRgba(modelColor, 0.4);
                
                return (
                  <button 
                    class="js-nav-trigger group c-glass-card rounded-2xl overflow-hidden text-left outline-none flex flex-col h-full" 
                    data-target="view-works" 
                    data-model-id={model.id}
                    data-title={model.name} 
                    data-bio={model.modelBio || ''}
                    data-image={displayImage}
                    data-color={modelColor}
                  >
                    <div class="aspect-square overflow-hidden relative flex-shrink-0">
                      <img src={avatarSrc} loading="lazy" decoding="async" alt={model.name} class="w-full h-full object-cover object-top group-hover:scale-110 transition-transform duration-700 ease-out" referrerpolicy="no-referrer" />
                      <div class="absolute inset-0 opacity-0 group-hover:opacity-40 transition-opacity duration-700 pointer-events-none mix-blend-overlay" style={`background: linear-gradient(to top, ${modelColor}, transparent);`}></div>
                    </div>
                    
                    <div class="p-3 lg:p-4 flex-grow backdrop-blur-md transition-colors duration-300" style={`background-color: ${cardTextBgColor}; border-top: 1px solid ${cardTextBorderColor};`}>
                      <h3 class="font-medium text-white text-base tracking-wide drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)]">{model.name}</h3>
                      <p class="text-xs text-white/80 mt-1 font-light drop-shadow-[0_1px_2px_rgba(0,0,0,0.8)]">{model.artworks?.nodes?.length || 0} Works</p>
                    </div>
                  </button>
                )
              })}
            </div>
          </div>

          <div id="view-works" class="view-section hidden">
            <button class="js-back-btn text-gray-400 hover:text-white mb-6 flex items-center text-sm transition-colors group font-light tracking-widest uppercase" data-target="view-categories">
              <span class="mr-2 transform group-hover:-translate-x-1 transition-transform">←</span> Back to Models
            </button>
            <h2 class="text-xl lg:text-2xl font-light mb-6 text-white border-b border-white/10 pb-4 tracking-tight" id="works-title">Selected Works</h2>
            <div class="grid grid-cols-2 gap-4 lg:gap-5" id="works-grid">
              {allArtworks.map((art: any) => {
                const src = secureUrl(art.featuredImage?.node?.sourceUrl) || placeholderImg;
                const variations = getVariationsArray(art);
                const modelColor = getValidColor(art.model?.memberColor);
                
                const workTextBgColor = hexToRgba(modelColor, 0.25);
                const workTextBorderColor = hexToRgba(modelColor, 0.3);

                return (
                  <button 
                    class="js-nav-trigger group block w-full text-left outline-none rounded-2xl js-work-item hidden flex flex-col h-full" 
                    data-target="view-detail"
                    data-model-id={art.model.id}
                    data-database-id={art.databaseId}
                    data-title={art.title} 
                    data-prompt={art.promptData || ''}
                    data-image={src}
                    data-variations={JSON.stringify(variations)}
                    data-likes={art.likeCount || 0}
                    data-comments={JSON.stringify(art.guestComments || [])}
                  >
                    <div class="c-glass-card rounded-2xl overflow-hidden flex flex-col h-full">
                      <div class="aspect-[4/5] overflow-hidden relative flex-shrink-0">
                        <img src={src} loading="lazy" decoding="async" alt={art.title} class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700 ease-out" referrerpolicy="no-referrer" />
                      </div>
                      <div class="p-4 flex-grow backdrop-blur-md transition-colors duration-300" style={`background-color: ${workTextBgColor}; border-top: 1px solid ${workTextBorderColor};`}>
                        <h3 class="font-medium text-white text-sm lg:text-base leading-tight tracking-wide drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)]">{art.title}</h3>
                      </div>
                    </div>
                  </button>
                );
              })}
            </div>
          </div>

          <div id="view-detail" class="view-section hidden">
            <button class="js-back-btn text-gray-400 hover:text-white mb-6 flex items-center text-sm transition-colors group font-light tracking-widest uppercase" data-target="view-works">
              <span class="mr-2 transform group-hover:-translate-x-1 transition-transform">←</span> Back to Works
            </button>
            <div class="flex overflow-x-auto lg:grid lg:grid-cols-3 xl:grid-cols-4 gap-3 lg:gap-3 mb-8 pb-4 lg:pb-0 snap-x snap-mandatory [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]" id="variation-gallery"></div>
            
            <div class="flex lg:hidden flex-col mt-4 border-t border-white/10 pt-8 gap-10">
              <div class="flex flex-col gap-4">
                <div class="flex items-center gap-3">
                  <button class="outline-none group transform active:scale-90 transition-transform" onclick="window.triggerLikeAnimation(event, true)">
                    <svg id="btn-like-icon-sp" viewBox="0 0 24 24" class="w-5 h-5 text-white transition-colors duration-300"><path fill="currentColor" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                  </button>
                  <span id="like-counter-sp" class="font-light text-white tabular-nums text-lg tracking-wider">0</span>
                  
                  <button class="ml-auto outline-none group transform active:scale-90 transition-transform relative" onclick="window.shareArtwork(event)">
                    <svg class="w-5 h-5 text-gray-400 hover:text-[#F43F5E] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path></svg>
                    <span class="share-toast absolute -top-8 left-1/2 -translate-x-1/2 bg-white text-black text-[10px] px-2 py-1 rounded opacity-0 transition-opacity pointer-events-none whitespace-nowrap shadow-lg">Copied!</span>
                  </button>
                </div>
                <button onclick="window.openCommentModal()" class="w-full bg-white/5 rounded-2xl px-5 py-4 border border-white/10 flex items-center justify-between text-left text-gray-400 hover:bg-white/10 transition-colors outline-none">
                  <span class="text-sm font-light">コメントを見る...</span>
                  <span class="text-xs bg-white/10 px-2 py-1 rounded-full text-white comment-badge-count">0</span>
                </button>
              </div>
            </div>
          </div>
    
        </div>

        <aside id="pc-sidebar" class="hidden max-lg:hidden absolute right-0 top-0 w-20 h-[calc(100dvh-90px)] border-l border-white/10 bg-[#151518]/90 backdrop-blur-2xl shadow-[-10px_0_30px_rgba(0,0,0,0.5)] items-center py-8 gap-6 z-10 transition-opacity duration-300 overflow-y-auto [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
          {models.map((model: any) => {
            const latestArtworkImg = secureUrl(model.artworks?.nodes?.[0]?.featuredImage?.node?.sourceUrl);
            const avatarSrc = secureUrl(model.modelAvatar?.node?.sourceUrl) || placeholderImg;
            const displayImage = latestArtworkImg || avatarSrc;
            const modelColor = getValidColor(model.memberColor);
            
            // ▼ 明るさに応じてツールチップの文字色を判定
            const textColors = getTextColorClasses(modelColor);
            const isLightColor = textColors.main.includes('text-[#0A0A0C]');
            const tooltipTextColor = isLightColor ? '#0A0A0C' : '#FFFFFF';

            return (
              <div 
                class="relative group cursor-pointer js-nav-trigger shrink-0" 
                data-target="view-works" 
                data-model-id={model.id} 
                data-title={model.name}
                data-bio={model.modelBio || ''}
                data-image={displayImage}
                data-color={modelColor}
                data-text-color={tooltipTextColor}
                onmouseenter="window.showSidebarTooltip(this)"
                onmouseleave="window.hideSidebarTooltip()"
              >
                <img src={avatarSrc} loading="lazy" decoding="async" class="w-12 h-12 rounded-full object-cover object-top border-2 border-transparent transition-colors shadow-lg" style={`--hover-color: ${modelColor};`} onmouseover="this.style.borderColor = this.style.getPropertyValue('--hover-color')" onmouseout="this.style.borderColor = 'transparent'" referrerpolicy="no-referrer" />
              </div>
            )
          })}
        </aside>

        <div id="interaction-footer" class="hidden max-lg:hidden absolute bottom-0 left-0 w-full h-[90px] bg-[#0A0A0C]/90 backdrop-blur-2xl border-t border-white/5 px-6 items-center gap-4 z-50">
          <button class="outline-none group transform active:scale-90 transition-transform flex items-center gap-2" onclick="window.triggerLikeAnimation(event, true)">
            <svg id="btn-like-icon" viewBox="0 0 24 24" class="w-5 h-5 text-white transition-colors duration-300"><path fill="currentColor" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            <span id="like-counter" class="font-light text-white tabular-nums text-lg tracking-wider">0</span>
          </button>
          
          <button onclick="window.openCommentModal()" class="flex-1 bg-white/5 rounded-full h-11 px-5 border border-white/5 flex items-center justify-between hover:bg-white/10 hover:border-[#F43F5E]/50 transition-colors outline-none group text-gray-400 hover:text-white mx-2">
            <span class="text-sm font-light">コメント...</span>
            <span class="text-xs bg-white/10 group-hover:bg-[#F43F5E] text-white px-2 py-0.5 rounded-full transition-colors comment-badge-count">0</span>
          </button>

          <button class="outline-none group transform active:scale-90 transition-transform relative p-2" onclick="window.shareArtwork(event)">
            <svg class="w-5 h-5 text-gray-400 hover:text-[#F43F5E] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path></svg>
            <span class="share-toast absolute -top-10 left-1/2 -translate-x-1/2 bg-white text-black text-[10px] px-2 py-1 rounded opacity-0 transition-opacity pointer-events-none whitespace-nowrap shadow-lg">Copied!</span>
          </button>
        </div>
      </section>

      <div id="sp-model-nav" class="lg:hidden fixed bottom-0 left-0 w-full bg-[#151518]/90 backdrop-blur-2xl border-t border-white/10 z-[60] transition-transform duration-300 translate-y-full hidden">
        <div class="flex overflow-x-auto gap-4 px-6 pt-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))] snap-x snap-mandatory [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
          {models.map((model: any) => {
            const latestArtworkImg = secureUrl(model.artworks?.nodes?.[0]?.featuredImage?.node?.sourceUrl);
            const avatarSrc = secureUrl(model.modelAvatar?.node?.sourceUrl) || placeholderImg;
            const displayImage = latestArtworkImg || avatarSrc;
            const modelColor = getValidColor(model.memberColor);

            return (
              <button 
                class="shrink-0 relative group cursor-pointer js-nav-trigger snap-center outline-none" 
                data-target="view-works" 
                data-model-id={model.id} 
                data-title={model.name}
                data-bio={model.modelBio || ''}
                data-image={displayImage}
                data-color={modelColor}
              >
                <img src={avatarSrc} loading="lazy" decoding="async" alt={model.name} class="w-12 h-12 rounded-full object-cover object-top border-2 border-transparent transition-colors shadow-md" style={`--active-color: ${modelColor};`} onmousedown="this.style.borderColor = this.style.getPropertyValue('--active-color')" onmouseup="this.style.borderColor = 'transparent'" referrerpolicy="no-referrer" />
              </button>
            )
          })}
        </div>
      </div>

      <SiteFooter 
        siteTitle={siteInfo.title} 
        siteDescription={siteInfo.description} 
        siteLogo="https://api.xx-ai-girls-miu.com/wp-content/uploads/2026/04/cropped-01.png" 
      />

    </main>

    <dialog id="comment-modal" class="bg-transparent m-auto p-0 w-full h-full max-w-md backdrop:bg-[#050505]/90 overflow-hidden outline-none z-[120]">
      <div class="bg-[#151518] rounded-3xl border border-white/10 shadow-2xl flex flex-col h-[80vh] max-h-[700px] w-[90%] max-w-sm mx-auto mt-[10vh] overflow-hidden transform scale-95 opacity-0 transition-all duration-300" id="comment-modal-content">
        <div class="p-4 px-6 border-b border-white/5 flex justify-between items-center bg-[#0A0A0C] shrink-0">
          <h3 class="text-white font-light tracking-wide">Comments <span class="text-gray-500 text-xs ml-2" id="modal-comment-count">0</span></h3>
          <button onclick="window.closeCommentModal()" class="text-gray-400 hover:text-[#F43F5E] outline-none transition-colors p-1">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
        </div>
        
        <div class="flex-1 overflow-y-auto p-6 scroll-smooth" id="comment-list">
          <!-- コメントがここに動的に入ります -->
        </div>

        <div class="p-4 border-t border-white/5 bg-[#0A0A0C] shrink-0 relative">
          <div id="reply-indicator" class="hidden absolute top-0 left-4 -translate-y-[calc(100%-1px)] bg-[#151518] border border-white/10 border-b-0 rounded-t-xl px-4 py-1.5 items-center gap-4 z-0 text-xs shadow-lg">
            <span class="text-gray-400 font-light"><span id="reply-indicator-name" class="text-white font-medium"></span> さんに返信中...</span>
            <button onclick="window.cancelReply()" class="text-gray-500 hover:text-[#F43F5E] outline-none p-1">✕</button>
          </div>

          <div id="comment-form-wrapper" class="relative z-10 bg-[#0A0A0C]">
            <input type="text" id="comment-author" placeholder="名前 (任意)" class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm mb-2 outline-none focus:border-[#F43F5E] transition-colors font-light" />
            <div class="flex gap-2">
              <input type="text" id="comment-content" placeholder="コメントを入力..." class="flex-1 bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm outline-none focus:border-[#F43F5E] transition-colors font-light" onkeydown="if(event.key==='Enter') window.submitComment()" />
              <button type="button" onclick="window.submitComment()" id="comment-submit-btn" class="bg-white/10 text-white px-4 py-2 rounded-lg text-sm font-light hover:bg-[#F43F5E] transition-colors outline-none shrink-0">送信</button>
            </div>
          </div>
        </div>
      </div>
    </dialog>

    <dialog id="lightbox" class="bg-transparent m-auto p-0 w-full h-full max-w-none max-h-none backdrop:bg-[#050505]/95 overflow-hidden outline-none z-[100]">
      <button onclick="window.closeLightbox()" class="fixed top-6 right-6 lg:top-12 lg:right-12 text-white hover:text-[#F43F5E] transition-colors p-3 rounded-full z-[120] bg-white/5 backdrop-blur-md border border-white/10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>

      <button id="lightbox-prev" class="fixed left-4 lg:left-8 top-1/2 -translate-y-1/2 z-[120] text-white hover:text-[#F43F5E] p-3 lg:p-4 rounded-full bg-black/50 backdrop-blur-md border border-white/10 hidden transition-colors outline-none" onclick="window.prevLightboxImage(event)">
        <svg class="w-6 h-6 lg:w-8 lg:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
      </button>
      <button id="lightbox-next" class="fixed right-4 lg:right-8 top-1/2 -translate-y-1/2 z-[120] text-white hover:text-[#F43F5E] p-3 lg:p-4 rounded-full bg-black/50 backdrop-blur-md border border-white/10 hidden transition-colors outline-none" onclick="window.nextLightboxImage(event)">
        <svg class="w-6 h-6 lg:w-8 lg:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </button>

      <div id="lightbox-container" class="relative w-full h-full overflow-auto flex cursor-grab active:cursor-grabbing select-none z-[100] touch-none">
        <div class="m-auto w-full h-full flex items-center justify-center p-4 lg:p-12 transition-transform duration-300 pointer-events-none" id="lightbox-scale-wrapper">
          <img id="lightbox-img" src="" class="max-h-[90vh] max-w-full w-auto h-auto shadow-2xl transition-all duration-500 ease-out pointer-events-auto" referrerpolicy="no-referrer" />
        </div>
      </div>
    </dialog>

    <script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/js/splide.min.js"></script>

    <script is:inline>
      let clickTimer = null;
      let lastTapTime = 0;
      let heroSlider = null;
      let currentModelData = { databaseId: 0, title: '', bio: '', prompt: '', image: '', likes: 0, comments: [], color: '#F43F5E' };
      let activeReplyId = 0; 

      /**
       * サイドバーのアイコンホバー時に表示されるツールチップの制御関数です。
       * メンバーカラーを取得して背景色と文字色を動的に変更します。
       */
      window.showSidebarTooltip = (el) => {
        const tooltip = document.getElementById('global-sidebar-tooltip');
        if(!tooltip) return;
        const rect = el.getBoundingClientRect();
        const color = el.getAttribute('data-color') || '#F43F5E';
        const textColor = el.getAttribute('data-text-color') || '#FFFFFF';
        
        tooltip.textContent = el.getAttribute('data-title');
        tooltip.style.backgroundColor = color;
        tooltip.style.color = textColor;
        // ▼ 白文字の時はドロップシャドウを薄くかけて可読性を担保
        tooltip.style.textShadow = textColor === '#FFFFFF' ? '0 1px 2px rgba(0,0,0,0.8)' : 'none';
        
        tooltip.style.top = (rect.top + rect.height / 2) + 'px';
        tooltip.style.right = (window.innerWidth - rect.left + 16) + 'px';
        tooltip.classList.remove('opacity-0');
      };

      window.hideSidebarTooltip = () => {
        const tooltip = document.getElementById('global-sidebar-tooltip');
        if(!tooltip) return;
        tooltip.classList.add('opacity-0');
      };

      document.addEventListener('astro:page-load', () => {
        if (window.Splide) {
          heroSlider = new window.Splide('#hero-slider', {
            type: 'loop', drag: true, arrows: false, pagination: true, autoplay: true, interval: 5000, pauseOnHover: true, speed: 1600, easing: 'cubic-bezier(0.25, 1, 0.5, 1)',
          }).mount();
        }

        const triggers = document.querySelectorAll('.js-nav-trigger');
        const backBtns = document.querySelectorAll('.js-back-btn');
        const views = document.querySelectorAll('.view-section');
        const heroTitle = document.getElementById('hero-title');
        const heroBio = document.getElementById('hero-bio');
        const heroPrompt = document.getElementById('hero-prompt');
        const pcFooter = document.getElementById('interaction-footer');
        const pcSidebar = document.getElementById('pc-sidebar');
        const spModelNav = document.getElementById('sp-model-nav');
        const defaultSiteTitle = heroTitle ? heroTitle.innerHTML : '';

        if (pcSidebar) {
          pcSidebar.addEventListener('scroll', window.hideSidebarTooltip, { passive: true });
        }

        document.addEventListener('keydown', (e) => {
          const lightbox = document.getElementById('lightbox');
          if (lightbox && lightbox.open) {
            if (e.key === 'ArrowRight') {
              window.nextLightboxImage();
            } else if (e.key === 'ArrowLeft') {
              window.prevLightboxImage();
            } else if (e.key === 'Escape') {
              window.closeLightbox();
            }
          }
        });

        const initDeepLink = () => {
          const hash = window.location.hash;
          if (hash.startsWith('#work-')) {
            const dbId = hash.replace('#work-', '');
            const targetBtn = document.querySelector(`.js-work-item[data-database-id="${dbId}"]`);
            if (targetBtn) setTimeout(() => targetBtn.click(), 100);
          }
        };
        initDeepLink();

        const cursor = document.getElementById('custom-cursor');
        const cursorText = document.getElementById('cursor-text');
        
        if (window.matchMedia("(pointer: fine)").matches) {
          document.addEventListener('mousemove', (e) => {
            if(!cursor) return;
            cursor.style.left = e.clientX + 'px';
            cursor.style.top = e.clientY + 'px';
          });
          
          document.addEventListener('mouseover', (e) => {
            if(!cursor) return;
            if(e.target.closest('button, a, input, .js-nav-trigger, .js-work-item, .js-variation-img')) {
               cursor.classList.add('is-hover');
               cursorText.textContent = '';
            } else if (e.target.closest('#hero-slider-wrapper, #hero-static-wrapper, #lightbox-container')) {
               cursor.classList.add('is-view');
               cursorText.textContent = 'VIEW';
            }
          });

          document.addEventListener('mouseout', (e) => {
            if(!cursor) return;
            if(e.target.closest('button, a, input, .js-nav-trigger, .js-work-item, .js-variation-img')) {
               cursor.classList.remove('is-hover');
            } else if (e.target.closest('#hero-slider-wrapper, #hero-static-wrapper, #lightbox-container')) {
               cursor.classList.remove('is-view');
               cursorText.textContent = '';
            }
          });
        }

        window.shareArtwork = (e) => {
          if(e) e.stopPropagation();
          const url = window.location.href;
          navigator.clipboard.writeText(url).then(() => {
            document.querySelectorAll('.share-toast').forEach(t => {
              t.classList.remove('opacity-0');
              setTimeout(() => t.classList.add('opacity-0'), 2000);
            });
          }).catch(err => {
            console.error('Failed to copy: ', err);
            alert('URLのコピーに失敗しました。');
          });
        };

        window.isPostLiked = (id) => {
          if(!id) return false;
          const liked = JSON.parse(localStorage.getItem('miu_liked_posts') || '[]');
          return liked.includes(id.toString());
        };
        window.markPostAsLiked = (id) => {
          if(!id) return;
          const liked = JSON.parse(localStorage.getItem('miu_liked_posts') || '[]');
          if(!liked.includes(id.toString())) {
            liked.push(id.toString());
            localStorage.setItem('miu_liked_posts', JSON.stringify(liked));
          }
        };

        window.updateStatsUI = () => {
          ['like-counter', 'like-counter-sp'].forEach(id => {
            const el = document.getElementById(id);
            if(el) el.textContent = currentModelData.likes.toLocaleString();
          });

          const isLiked = window.isPostLiked(currentModelData.databaseId);
          ['btn-like-icon', 'btn-like-icon-sp'].forEach(id => {
            const icon = document.getElementById(id);
            if(icon) {
              if(isLiked) icon.classList.add(`text-[${currentModelData.color}]`, 'fill-current');
              else icon.classList.remove(`text-[${currentModelData.color}]`, 'fill-current');
            }
          });
          window.renderComments();
        };

        window.fetchLiveStats = (postId) => {
          if(!window.WP_GRAPHQL_URL || !postId) return;
          fetch(window.WP_GRAPHQL_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              query: `query GetLiveStats($postId: Int!) { liveArtworkStats(postId: $postId) { likeCount guestComments { id parentId author content date } } }`,
              variables: { postId: parseInt(postId) }
            })
          })
          .then(res => res.json())
          .then(res => {
            const stats = res?.data?.liveArtworkStats;
            if(stats && currentModelData.databaseId == postId) {
              currentModelData.likes = stats.likeCount || 0;
              currentModelData.comments = stats.guestComments || [];
              window.updateStatsUI();
            }
          })
          .catch(err => console.error(err));
        };

        window.setReplyTo = (parentId, authorName) => {
          activeReplyId = parentId;
          const indicator = document.getElementById('reply-indicator');
          const nameSpan = document.getElementById('reply-indicator-name');
          if (indicator && nameSpan) {
            nameSpan.textContent = authorName || '名無し';
            indicator.classList.remove('hidden');
            indicator.classList.add('flex');
          }
          document.getElementById('comment-content')?.focus();
        };

        window.cancelReply = () => {
          activeReplyId = 0;
          const indicator = document.getElementById('reply-indicator');
          if (indicator) {
            indicator.classList.add('hidden');
            indicator.classList.remove('flex');
          }
        };

        const buildCommentHtml = (c, isReply = false) => `
          <div class="bg-white/5 border border-white/5 rounded-2xl p-4 ${isReply ? `ml-6 mt-2 border-l-2 border-l-[${currentModelData.color}]/50` : ''}">
            <div class="flex items-baseline justify-between mb-2">
              <span class="text-white font-medium">${c.author || '名無しさん'}</span>
              <span class="text-gray-500 text-xs">${c.date ? new Date(c.date).toLocaleDateString() : 'Just now'}</span>
            </div>
            <p class="text-gray-300 font-light leading-relaxed mb-3">${c.content}</p>
            ${!isReply ? `<button onclick="window.setReplyTo(${c.id}, '${c.author || '名無しさん'}')" class="text-xs text-gray-500 hover:text-[${currentModelData.color}] transition-colors outline-none flex items-center gap-1"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path></svg> 返信する</button>` : ''}
          </div>
        `;

        window.renderComments = () => {
          const list = document.getElementById('comment-list');
          if (!list) return;
          
          if (currentModelData.comments.length === 0) {
            list.innerHTML = '<p class="text-gray-500 font-light text-center py-10 mt-10">まだコメントはありません。<br/>最初のコメントを投稿しよう！</p>';
          } else {
            const topComments = currentModelData.comments.filter(c => !c.parentId || c.parentId === 0);
            list.innerHTML = `<div class="space-y-4 pb-4">` + topComments.map(c => {
              const replies = currentModelData.comments.filter(r => r.parentId === c.id);
              let html = buildCommentHtml(c, false);
              if (replies.length > 0) {
                html += `<div class="space-y-2 mt-2">` + replies.map(r => buildCommentHtml(r, true)).join('') + `</div>`;
              }
              return html;
            }).join('') + `</div>`;
          }

          document.querySelectorAll('.comment-badge-count').forEach(el => el.textContent = currentModelData.comments.length);
          const modalCount = document.getElementById('modal-comment-count');
          if(modalCount) modalCount.textContent = currentModelData.comments.length;
        };

        window.submitComment = () => {
          const authorInput = document.getElementById('comment-author');
          const contentInput = document.getElementById('comment-content');
          const submitBtn = document.getElementById('comment-submit-btn');
          
          const author = authorInput.value.trim() || '名無しさん';
          const content = contentInput.value.trim();
          
          if (!content) { alert("コメントが入力されていません！"); return; }
          if (!currentModelData.databaseId) { alert("エラー：作品のデータが取得できません。"); return; }

          submitBtn.disabled = true;
          submitBtn.textContent = '送信中...';

          if(window.WP_GRAPHQL_URL) {
            fetch(window.WP_GRAPHQL_URL, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                query: `mutation SubmitComment($postId: Int!, $author: String!, $content: String!, $parentId: Int) { submitGuestComment(input: {postId: $postId, author: $author, content: $content, parentId: $parentId}) { success message } }`,
                variables: { 
                  postId: parseInt(currentModelData.databaseId), 
                  author, 
                  content,
                  parentId: activeReplyId || 0 
                }
              })
            })
            .then(res => res.json())
            .then(data => {
              if (data?.data?.submitGuestComment?.success) {
                contentInput.value = '';
                window.cancelReply(); 
                window.fetchLiveStats(currentModelData.databaseId);
                const list = document.getElementById('comment-list');
                setTimeout(() => list.scrollTop = list.scrollHeight, 300);
              } else {
                const errMsg = data?.data?.submitGuestComment?.message || data?.errors?.[0]?.message || 'サーバー側で拒否されました';
                alert('送信に失敗しました: ' + errMsg);
              }
            })
            .catch(err => {
              console.error('Comment failed', err);
              alert('通信エラーが発生しました。');
            })
            .finally(() => {
              submitBtn.disabled = false;
              submitBtn.textContent = '送信';
            });
          }
        };

        window.updateHeroImage = (newSrc) => {
          const staticImg = document.getElementById('hero-static-img');
          const staticBg = document.getElementById('hero-static-bg');
          if (staticImg && staticBg && newSrc && staticImg.src !== newSrc) {
            staticImg.classList.add('opacity-0'); staticBg.classList.add('opacity-0');
            setTimeout(() => {
              const preloader = new Image(); preloader.src = newSrc;
              preloader.onload = () => {
                staticImg.src = newSrc; staticBg.src = newSrc;
                staticImg.classList.remove('opacity-0'); staticBg.classList.remove('opacity-0');
                staticImg.classList.remove('scale-100'); staticImg.classList.add('scale-105');
                setTimeout(() => { staticImg.classList.remove('scale-105'); staticImg.classList.add('scale-100'); }, 50);
              };
            }, 300);
          }
        };

        window.toggleHeroMode = (mode) => { 
          const sliderWrapper = document.getElementById('hero-slider-wrapper');
          const staticWrapper = document.getElementById('hero-static-wrapper');
          if (mode === 'static') {
            if (heroSlider && heroSlider.Components.Autoplay) heroSlider.Components.Autoplay.pause();
            if(sliderWrapper) { sliderWrapper.classList.add('opacity-0'); setTimeout(() => sliderWrapper.classList.add('hidden'), 700); }
            if(staticWrapper) { staticWrapper.classList.remove('hidden'); setTimeout(() => staticWrapper.classList.remove('opacity-0'), 50); }
          } else {
            if (heroSlider && heroSlider.Components.Autoplay) heroSlider.Components.Autoplay.play();
            if(staticWrapper) { staticWrapper.classList.add('opacity-0'); setTimeout(() => staticWrapper.classList.add('hidden'), 700); }
            if(sliderWrapper) { sliderWrapper.classList.remove('hidden'); setTimeout(() => sliderWrapper.classList.remove('opacity-0'), 50); }
          }
        };

        window.handleHeroInteraction = (e) => {
          if (e) e.stopPropagation();
          const currentTime = new Date().getTime();
          const tapLength = currentTime - lastTapTime;
          lastTapTime = currentTime;

          const isTopPage = document.getElementById('view-categories').classList.contains('active');
          const isDetailPage = document.getElementById('view-detail').classList.contains('active');
          
          let currentImgSrc = "";
          if (isTopPage) {
            const activeSlideImg = document.querySelector('.splide__slide.is-active .js-main-img');
            currentImgSrc = activeSlideImg ? activeSlideImg.src : "";
          } else {
            const staticImg = document.getElementById('hero-static-img');
            currentImgSrc = staticImg ? staticImg.src : "";
          }

          if (clickTimer !== null || (tapLength < 300 && tapLength > 0)) {
            if(clickTimer) clearTimeout(clickTimer);
            clickTimer = null;
            if (isDetailPage) window.triggerLikeAnimation(e);
            else if (!isDetailPage) window.openLightbox(currentImgSrc, isTopPage ? Array.from(document.querySelectorAll('.splide__slide:not(.splide__slide--clone) .js-main-img')).map(img => img.src) : [currentImgSrc]);
          } else {
            clickTimer = setTimeout(() => {
              clickTimer = null;
              let gallery = [currentImgSrc];
              if (isTopPage) gallery = Array.from(document.querySelectorAll('.splide__slide:not(.splide__slide--clone) .js-main-img')).map(img => img.src);
              else if (isDetailPage) gallery = window.currentDetailGallery || [currentImgSrc];
              if (currentImgSrc) window.openLightbox(currentImgSrc, gallery);
            }, 300);
          }
        };

        window.triggerLikeAnimation = (e, fromButton = false) => {
          if (!currentModelData.databaseId) return;
          if (window.isPostLiked(currentModelData.databaseId)) return;

          window.markPostAsLiked(currentModelData.databaseId);
          currentModelData.likes++;
          window.updateStatsUI();

          if (!fromButton) {
            const heart = document.createElement('div');
            heart.innerHTML = `<svg viewBox="0 0 24 24" class="w-32 h-32 fill-current" style="color: ${currentModelData.color}; filter: drop-shadow(0 0 30px ${currentModelData.color});"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>`;
            heart.className = 'fixed pointer-events-none z-[9999] transform -translate-x-1/2 -translate-y-1/2 animate-heart-burst';
            heart.style.left = (e.clientX || window.innerWidth/2) + 'px';
            heart.style.top = (e.clientY || window.innerHeight/2) + 'px';
            document.body.appendChild(heart);
            setTimeout(() => heart.remove(), 1000);
          }

          if(window.WP_GRAPHQL_URL) {
            fetch(window.WP_GRAPHQL_URL, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                query: `mutation IncrementLike($postId: Int!) { incrementLike(input: {postId: $postId}) { newCount } }`,
                variables: { postId: parseInt(currentModelData.databaseId) }
              })
            }).catch(err => console.error('Like request failed', err));
          }
        };

        window.switchView = (targetId, newImage, newTitle, newBio, newPrompt) => {
          views.forEach(view => {
            if (view.id === targetId) { view.classList.remove('hidden'); setTimeout(() => view.classList.add('active'), 10); } 
            else { view.classList.remove('active'); setTimeout(() => { if(!view.classList.contains('active')) view.classList.add('hidden'); }, 300); }
          });

          if (targetId === 'view-detail') {
            window.history.replaceState(null, '', `#work-${currentModelData.databaseId}`);
            
            if(pcFooter) { pcFooter.classList.remove('hidden'); pcFooter.classList.add('lg:flex'); }
            if(pcSidebar) { pcSidebar.classList.remove('hidden'); pcSidebar.classList.add('lg:flex-col', 'lg:flex'); }
            if(spModelNav) { spModelNav.classList.remove('hidden'); setTimeout(() => spModelNav.classList.remove('translate-y-full'), 10); }
            
            window.toggleHeroMode('static');
            if(heroBio) { heroBio.classList.add('opacity-0'); setTimeout(() => heroBio.classList.add('hidden'), 300); }
            if(heroPrompt) {
              if (newPrompt) { heroPrompt.innerHTML = newPrompt; heroPrompt.classList.remove('hidden'); setTimeout(() => heroPrompt.classList.remove('opacity-0'), 50); } 
              else { heroPrompt.classList.add('opacity-0'); setTimeout(() => heroPrompt.classList.add('hidden'), 300); }
            }
            if(newTitle && heroTitle) { heroTitle.classList.add('opacity-0'); setTimeout(() => { heroTitle.innerHTML = newTitle; heroTitle.classList.remove('opacity-0'); }, 300); }
            if(newImage) window.updateHeroImage(newImage);

            window.updateStatsUI();
            window.fetchLiveStats(currentModelData.databaseId);

          } else if (targetId === 'view-works') {
            window.history.replaceState(null, '', window.location.pathname);
            
            if(pcFooter) { pcFooter.classList.add('hidden'); pcFooter.classList.remove('lg:flex'); }
            if(pcSidebar) { pcSidebar.classList.remove('hidden'); pcSidebar.classList.add('lg:flex-col', 'lg:flex'); }
            if(spModelNav) { spModelNav.classList.remove('hidden'); setTimeout(() => spModelNav.classList.remove('translate-y-full'), 10); }
            window.toggleHeroMode('static');
            if(heroPrompt) { heroPrompt.classList.add('opacity-0'); setTimeout(() => heroPrompt.classList.add('hidden'), 300); }
            if(newTitle && heroTitle) { heroTitle.classList.add('opacity-0'); setTimeout(() => { heroTitle.innerHTML = newTitle; heroTitle.classList.remove('opacity-0'); }, 300); }
            if(heroBio) { heroBio.classList.add('opacity-0'); setTimeout(() => { if (newBio) { heroBio.innerHTML = newBio; heroBio.classList.remove('hidden'); setTimeout(() => heroBio.classList.remove('opacity-0'), 50); } else { heroBio.classList.add('hidden'); } }, 300); }
            if(newImage) window.updateHeroImage(newImage);
          } else {
            window.history.replaceState(null, '', window.location.pathname);
            
            if(pcFooter) { pcFooter.classList.add('hidden'); pcFooter.classList.remove('lg:flex'); }
            if(pcSidebar) { pcSidebar.classList.add('hidden'); pcSidebar.classList.remove('lg:flex-col', 'lg:flex'); }
            if(spModelNav) { spModelNav.classList.add('translate-y-full'); setTimeout(() => spModelNav.classList.add('hidden'), 300); }
            window.toggleHeroMode('slider');
            if(heroPrompt) { heroPrompt.classList.add('opacity-0'); setTimeout(() => heroPrompt.classList.add('hidden'), 300); }
            if(heroTitle) { heroTitle.classList.add('opacity-0'); setTimeout(() => { heroTitle.innerHTML = defaultSiteTitle; heroTitle.classList.remove('opacity-0'); }, 300); }
            if(heroBio) { heroBio.classList.add('opacity-0'); setTimeout(() => heroBio.classList.add('hidden'), 300); }
          }
        };

        triggers.forEach(btn => {
          btn.addEventListener('click', () => {
            const target = btn.getAttribute('data-target');
            const modelId = btn.getAttribute('data-model-id');
            const newImage = btn.getAttribute('data-image');
            const newTitle = btn.getAttribute('data-title');
            const newBio = btn.getAttribute('data-bio');
            const newPrompt = btn.getAttribute('data-prompt');
            const newColor = btn.getAttribute('data-color') || '#F43F5E'; 

            if (target === 'view-works' && modelId) {
              currentModelData = { ...currentModelData, title: newTitle, bio: newBio, prompt: '', image: newImage, color: newColor };
              document.querySelectorAll('.js-work-item').forEach(item => { item.getAttribute('data-model-id') === modelId ? item.classList.remove('hidden') : item.classList.add('hidden'); });
              const worksTitle = document.getElementById('works-title');
              if (worksTitle && newTitle) worksTitle.textContent = `${newTitle}'s Works`;
            }

            if (target === 'view-detail') {
              const variations = JSON.parse(btn.getAttribute('data-variations') || '[]');
              window.currentDetailGallery = variations; 
              
              currentModelData.databaseId = btn.getAttribute('data-database-id');
              currentModelData.likes = parseInt(btn.getAttribute('data-likes') || '0');
              currentModelData.comments = JSON.parse(btn.getAttribute('data-comments') || '[]');

              const gallery = document.getElementById('variation-gallery');
              if (gallery) {
                gallery.innerHTML = variations.map(url => `
                  <button class="shrink-0 w-24 sm:w-32 lg:w-full aspect-square overflow-hidden rounded-xl outline-none group border border-white/5 transition-colors snap-center" style="--hover-border: ${newColor}80;" onmouseover="this.style.borderColor = this.style.getPropertyValue('--hover-border')" onmouseout="this.style.borderColor = 'rgba(255,255,255,0.05)'" onclick="window.updateHeroImage('${url}')">
                    <img src="${url}" class="js-variation-img w-full h-full object-cover group-hover:scale-110 transition-all duration-500 ease-out" referrerpolicy="no-referrer" />
                  </button>
                `).join('');
              }
            }

            window.switchView(target, newImage, newTitle, newBio, newPrompt);
            document.getElementById('right-panel')?.scrollTo({ top: 0, behavior: 'smooth' });
          });
        });

        backBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            const target = btn.getAttribute('data-target');
            if (target === 'view-works') { window.switchView(target, currentModelData.image, currentModelData.title, currentModelData.bio, ''); } 
            else { window.switchView(target); }
          });
        });

        window.openCommentModal = () => {
          const modal = document.getElementById('comment-modal');
          const content = document.getElementById('comment-modal-content');
          if(modal && content) {
            modal.showModal();
            setTimeout(() => { content.style.transform = 'scale(1)'; content.style.opacity = '1'; }, 10);
            modal.onclick = (e) => {
              if (e.target === modal) window.closeCommentModal();
            };
          }
        };

        window.closeCommentModal = () => {
          const content = document.getElementById('comment-modal-content');
          if(content) {
            content.style.transform = 'scale(0.95)'; content.style.opacity = '0';
            setTimeout(() => {
              document.getElementById('comment-modal').close();
              window.cancelReply(); 
            }, 300);
          }
        };

        window.changeLightboxImage = (newSrc) => { const img = document.getElementById('lightbox-img'); if (!img || img.src === newSrc) return; img.classList.add('opacity-0', 'scale-95'); setTimeout(() => { const preloader = new Image(); preloader.src = newSrc; preloader.onload = () => { img.src = newSrc; img.classList.remove('scale-150'); img.classList.remove('scale-95'); img.classList.add('scale-105'); img.classList.remove('opacity-0'); setTimeout(() => { img.classList.remove('scale-105'); }, 50); }; }, 300); };
        window.openLightbox = (src, gallery = []) => { const img = document.getElementById('lightbox-img'); const dialog = document.getElementById('lightbox'); const prevBtn = document.getElementById('lightbox-prev'); const nextBtn = document.getElementById('lightbox-next'); if (img && dialog) { img.src = src; img.classList.remove('scale-150', 'opacity-0', 'scale-95', 'scale-105'); window.currentGallery = gallery.length > 0 ? gallery : [src]; window.currentGalleryIndex = window.currentGallery.indexOf(src); if(window.currentGalleryIndex === -1) window.currentGalleryIndex = 0; if (window.currentGallery.length > 1) { prevBtn.classList.remove('hidden'); nextBtn.classList.remove('hidden'); } else { prevBtn.classList.add('hidden'); nextBtn.classList.add('hidden'); } dialog.showModal(); if(heroSlider && heroSlider.Components.Autoplay) heroSlider.Components.Autoplay.pause(); } };
        window.prevLightboxImage = (e) => { if(e) e.stopPropagation(); if (!window.currentGallery || window.currentGallery.length <= 1) return; window.currentGalleryIndex = (window.currentGalleryIndex - 1 + window.currentGallery.length) % window.currentGallery.length; window.changeLightboxImage(window.currentGallery[window.currentGalleryIndex]); };
        window.nextLightboxImage = (e) => { if(e) e.stopPropagation(); if (!window.currentGallery || window.currentGallery.length <= 1) return; window.currentGalleryIndex = (window.currentGalleryIndex + 1) % window.currentGallery.length; window.changeLightboxImage(window.currentGallery[window.currentGalleryIndex]); };
        window.closeLightbox = () => { const dialog = document.getElementById('lightbox'); if (dialog) { dialog.close(); const isTopPage = document.getElementById('view-categories').classList.contains('active'); if(heroSlider && isTopPage && heroSlider.Components.Autoplay) heroSlider.Components.Autoplay.play(); } };
        
        const lightboxContainer = document.getElementById('lightbox-container'); 
        let isDragging = false; 
        let startX, startY, scrollLeft, scrollTop; 
        let touchStartX = 0; 
        let touchStartY = 0; 
        const startDrag = (x, y) => { isDragging = true; lightboxContainer.style.cursor = 'grabbing'; startX = x - lightboxContainer.offsetLeft; startY = y - lightboxContainer.offsetTop; scrollLeft = lightboxContainer.scrollLeft; scrollTop = lightboxContainer.scrollTop; }; 
        const stopDrag = () => { isDragging = false; lightboxContainer.style.cursor = 'grab'; }; 
        const moveDrag = (x, y) => { if(!isDragging) return; lightboxContainer.scrollLeft = scrollLeft - (x - startX); lightboxContainer.scrollTop = scrollTop - (y - startY); }; 
        lightboxContainer.addEventListener('mousedown', (e) => startDrag(e.pageX, e.pageY)); 
        window.addEventListener('mouseup', stopDrag); 
        window.addEventListener('mousemove', (e) => { if (isDragging) e.preventDefault(); moveDrag(e.pageX, e.pageY); }); 
        
        lightboxContainer.addEventListener('touchstart', (e) => { 
          touchStartX = e.touches[0].clientX; 
          touchStartY = e.touches[0].clientY; 
          startDrag(e.touches[0].pageX, e.touches[0].pageY); 
        }, {passive: true}); 
        
        lightboxContainer.addEventListener('touchend', (e) => { 
          stopDrag(); 
          const img = document.getElementById('lightbox-img'); 
          if (img && !img.classList.contains('scale-150') && e.changedTouches.length > 0) { 
            const touchEndX = e.changedTouches[0].clientX; 
            const touchEndY = e.changedTouches[0].clientY; 
            const diffX = touchStartX - touchEndX; 
            const diffY = touchStartY - touchEndY; 
            
            if (Math.abs(diffX) > 40 && Math.abs(diffX) > Math.abs(diffY)) { 
              if (diffX > 0) { window.nextLightboxImage(); } 
              else { window.prevLightboxImage(); } 
            } 
          } 
        }); 
        window.addEventListener('touchmove', (e) => moveDrag(e.touches[0].pageX, e.touches[0].pageY), {passive: true}); 
        lightboxContainer.addEventListener('click', (e) => { if (Math.abs(scrollLeft - lightboxContainer.scrollLeft) > 5 || Math.abs(scrollTop - lightboxContainer.scrollTop) > 5) return; const img = document.getElementById('lightbox-img'); if (!img || e.target.closest('button')) return; img.classList.toggle('scale-150'); });
      });
    </script>
  </body>
</html>
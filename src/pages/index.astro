---
// src/pages/index.astro
import { ClientRouter } from 'astro:transitions';
import '../styles/app.scss';
import { getGalleryData } from '../lib/wp';

const { siteInfo, sliders, models } = await getGalleryData();

const allArtworks = models.flatMap((model: any) => 
  model.artworks?.nodes?.map((art: any) => ({ ...art, model })) || []
);

const placeholderImg = "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=1200&auto=format&fit=crop";
const wpGraphqlUrl = import.meta.env.PUBLIC_WP_GRAPHQL_URL || '';

const secureUrl = (url: string) => {
  if (!url) return '';
  let httpsUrl = url.replace(/^http:\/\//i, 'https://');
  if (wpGraphqlUrl && !httpsUrl.includes('unsplash.com')) {
    try {
      const wpOrigin = new URL(wpGraphqlUrl).origin;
      const urlObj = new URL(httpsUrl);
      if (urlObj.origin !== wpOrigin) {
        urlObj.protocol = new URL(wpOrigin).protocol;
        urlObj.hostname = new URL(wpOrigin).hostname;
        urlObj.port = new URL(wpOrigin).port;
        return urlObj.toString();
      }
    } catch (e) {}
  }
  return httpsUrl;
};

const hexToRgba = (hex: string, alpha: number = 0.5) => {
  const validHex = hex && hex.trim() !== '' ? hex : '#F43F5E';
  const r = parseInt(validHex.slice(1, 3), 16);
  const g = parseInt(validHex.slice(3, 5), 16);
  const b = parseInt(validHex.slice(5, 7), 16);
  if (isNaN(r) || isNaN(g) || isNaN(b)) {
     return `rgba(244, 63, 94, ${alpha})`;
  }
  return `rgba(${r}, ${g}, ${b}, ${alpha})`;
};

const getValidColor = (color: string) => (color && color.trim() !== '') ? color : '#F43F5E';

const getTextColorClasses = (hex: string) => {
  const validHex = hex && hex.trim() !== '' ? hex : '#F43F5E';
  const r = parseInt(validHex.slice(1, 3), 16);
  const g = parseInt(validHex.slice(3, 5), 16);
  const b = parseInt(validHex.slice(5, 7), 16);
  
  if (isNaN(r) || isNaN(g) || isNaN(b)) {
     return { main: 'text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)]', sub: 'text-white/80 drop-shadow-[0_1px_2px_rgba(0,0,0,0.8)]' };
  }
  
  const yiq = ((r * 299) + (g * 587) + (b * 114)) / 1000;
  
  if (yiq >= 128) {
    return { main: 'text-[#0A0A0C] font-medium', sub: 'text-[#0A0A0C]/80 font-normal' };
  } else {
    return { main: 'text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] font-light', sub: 'text-white/80 drop-shadow-[0_1px_2px_rgba(0,0,0,0.8)]' };
  }
};

const globalBaseColor = models.length > 0 ? getValidColor(models[0].memberColor) : '#F43F5E';

const displaySliders = sliders && sliders.length > 0 
  ? sliders 
  : [{ featuredImage: { node: { sourceUrl: placeholderImg } }, title: 'Welcome' }];

const getVariationsArray = (art: any) => {
  const images = art.orderedImages;
  if (images && images.length > 0) {
    return images.map((img: any) => secureUrl(img.sourceUrl));
  }
  return [secureUrl(art.featuredImage?.node?.sourceUrl) || placeholderImg];
};

// WordPressから取得した文字列に含まれるHTMLエンティティ（&#039; など）を元の文字に変換する関数です
const decodeHtmlEntities = (str: string) => {
  if (!str) return '';
  return str
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&#039;/g, "'")
    .replace(/&#8217;/g, '’')
    .replace(/&#8216;/g, '‘');
};

// SEOやメタデータ用の変数を定義します（デコード処理を挟んでいます）
const siteTitle = decodeHtmlEntities(siteInfo.title) || "Miu's Gallery | AI Girls Gallery";
const siteDescription = decodeHtmlEntities(siteInfo.description) || "オリジナルAIキャラクター「美羽」たちの美麗な写真をお届けするギャラリーサイトです。";
const siteUrl = Astro.site ? Astro.site.toString() : "https://xx-ai-girls-miu.com/";
const ogImageUrl = secureUrl(displaySliders[0]?.featuredImage?.node?.sourceUrl) || placeholderImg;

// 検索エンジン向けの構造化データ（JSON-LD）を構築します
const schemaLD = {
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  "name": siteTitle,
  "description": siteDescription,
  "url": siteUrl,
  "image": ogImageUrl,
  "author": {
    "@type": "Person",
    "name": "Miu"
  }
};
---

<html lang="ja" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    
    <!-- SEOメタデータとOGPの設定を行います -->
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <link rel="canonical" href={siteUrl} />
    
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImageUrl} />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- ファビコンとApple Touch Iconの設定をPNG形式で追加します -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#050505" />
    
    <ClientRouter />
    
    <!-- Service Workerの登録とキャッシュ自動更新処理を追加します -->
    <script>
      import { registerSW } from 'virtual:pwa-register';
      
      if ('serviceWorker' in navigator) {
        const updateSW = registerSW({
          immediate: true,
          onNeedRefresh() {
            // 新しいビルドがデプロイされた際、古いキャッシュを破棄して強制リフレッシュします
            updateSW(true);
          }
        });
      }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500&family=Noto+Sans+JP:wght@300;400;500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/css/splide.min.css" rel="stylesheet">
    
    <!-- 構造化データを挿入します -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaLD)} />

    <script src="https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js" defer></script>
    <script is:inline>
      window.OneSignalDeferred = window.OneSignalDeferred || [];
      OneSignalDeferred.push(async function(OneSignal) {
        await OneSignal.init({
          appId: "06418ce1-102a-4a7b-a88b-069b594cf919",
          promptOptions: {
            slidedown: {
              prompts: [
                {
                  type: "push",
                  autoPrompt: true,
                  text: {
                    actionMessage: "新しいギャラリーが追加されたら通知を受け取りますか？",
                    acceptButton: "受け取る",
                    cancelButton: "あとで",
                  },
                  delay: {
                    pageViews: 1,
                    timeDelay: 5 
                  }
                }
              ]
            }
          }
        });
      });
    </script>

    <script define:vars={{ wpGraphqlUrl }}>
      window.WP_GRAPHQL_URL = wpGraphqlUrl;
    </script>
    <style>
      @keyframes swipe-hand {
        0% { transform: translateX(20px); opacity: 0; }
        20% { opacity: 1; }
        80% { transform: translateX(-20px); opacity: 1; }
        100% { transform: translateX(-30px); opacity: 0; }
      }
      .animate-swipe-hand { animation: swipe-hand 1.5s ease-in-out infinite; }
      .hide-scrollbar::-webkit-scrollbar { display: none; }
      .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
  </head>
  <body class="bg-[#050505] text-gray-200 antialiased selection:bg-[#F43F5E] selection:text-white max-lg:overflow-x-hidden max-lg:min-h-screen lg:overflow-hidden u-bg-noise font-light flex flex-col lg:h-[100dvh]">
    
    <!-- PWA Install Prompt -->
    <div id="pwa-install-prompt" class="fixed bottom-4 left-1/2 -translate-x-1/2 z-[300] w-[92%] max-w-sm bg-[#151518]/95 backdrop-blur-2xl border border-white/10 rounded-2xl shadow-[0_10px_40px_rgba(0,0,0,0.8)] p-4 lg:p-5 flex flex-col gap-3 translate-y-[150%] transition-transform duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)]">
      <div class="flex items-start justify-between gap-3">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl overflow-hidden shrink-0 border border-[#F43F5E]/50 bg-black">
            <img src="https://api.xx-ai-girls-miu.com/wp-content/uploads/2026/04/cropped-01.png" alt="App Icon" class="w-full h-full object-cover" />
          </div>
          <div>
            <h3 class="text-white text-sm font-medium tracking-wide">アプリとして追加</h3>
            <p class="text-gray-400 text-xs mt-0.5 leading-snug">ホーム画面に追加してフルスクリーンでお楽しみください。</p>
          </div>
        </div>
        <button id="pwa-close-btn" aria-label="閉じる" class="text-gray-500 hover:text-white transition-colors p-1 shrink-0 -mt-1 -mr-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>

      <div id="pwa-ios-instructions" class="hidden text-xs text-gray-300 bg-white/5 rounded-lg p-3 border border-white/5">
        <ol class="list-decimal list-inside space-y-1 ml-1">
          <li>画面下部の <svg class="w-4 h-4 inline-block align-text-bottom mx-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg> 共有ボタンをタップ</li>
          <li>「<span class="font-medium text-white">ホーム画面に追加</span>」をタップ</li>
        </ol>
      </div>

      <button id="pwa-install-btn" class="hidden w-full bg-[#F43F5E] hover:bg-[#E11D48] text-white text-sm font-medium py-2.5 rounded-xl transition-colors shadow-[0_4px_12px_rgba(244,63,94,0.3)]">
        インストールする
      </button>
    </div>

    <div id="custom-cursor" class="hidden lg:flex" aria-hidden="true"><span id="cursor-text"></span></div>

    <div id="global-sidebar-tooltip" class="fixed z-[150] text-xs px-3 py-1.5 rounded-lg opacity-0 transition-opacity duration-200 pointer-events-none whitespace-nowrap shadow-xl border border-white/20 font-light tracking-wide -translate-y-1/2" aria-hidden="true"></div>

    <aside id="global-sns-nav" class="fixed right-4 bottom-28 z-[80] flex flex-col gap-3 lg:hidden transition-transform duration-500 ease-out" aria-label="ソーシャルリンク">
      <a href="https://www.instagram.com/xx.ai.girls.miu0402/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-10 h-10 rounded-full bg-[#151518]/80 backdrop-blur-xl border border-white/10 flex items-center justify-center text-white hover:text-[#F43F5E] hover:border-[#F43F5E]/50 transition-all shadow-[0_8px_32px_0_rgba(0,0,0,0.5)]">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </a>
      <a href="https://www.patreon.com/cw/u73055670?utm_medium=unknown&utm_source=join_link&utm_campaign=creatorshare_creator&utm_content=copyLink" target="_blank" rel="noopener noreferrer" aria-label="Patreon" class="w-10 h-10 rounded-full bg-[#151518]/80 backdrop-blur-xl border border-white/10 flex items-center justify-center text-white hover:text-[#F43F5E] hover:border-[#F43F5E]/50 transition-all shadow-[0_8px_32px_0_rgba(0,0,0,0.5)]">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 1080 1080"><path d="M1033.05,324.45c-0.19-137.9-107.59-250.92-233.6-291.7c-156.48-50.64-362.86-43.3-512.28,27.2 C106.07,145.41,49.18,332.61,47.06,519.31c-1.74,153.5,13.58,557.79,241.62,560.67c169.44,2.15,194.67-216.18,273.07-321.33 c55.78-74.81,127.6-95.94,216.01-117.82C929.71,603.22,1033.27,483.3,1033.05,324.45z"></path></svg>
      </a>
    </aside>

    <main class="flex-1 flex flex-col lg:flex-row w-full bg-transparent max-lg:overflow-x-hidden lg:overflow-hidden relative z-10">
      
      <section 
        class="w-full h-[75svh] lg:h-full lg:w-[70%] flex-none relative bg-black overflow-hidden group cursor-zoom-in touch-manipulation select-none shadow-2xl shrink-0 order-1"
        aria-label="ギャラリーハイライト"
        onclick="window.handleHeroInteraction(event)"
      >
        <div id="hero-expand-hint" class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-0 transition-opacity duration-700 z-30 hidden">
          <div class="relative flex items-center justify-center">
            <div class="absolute w-24 h-24 bg-white/20 rounded-full animate-ping"></div>
            <div class="absolute w-16 h-16 bg-white/30 rounded-full animate-pulse"></div>
            <span class="relative bg-[#0A0A0C]/60 backdrop-blur-md text-white text-[10px] lg:text-xs font-medium px-4 py-2 rounded-full border border-white/20 whitespace-nowrap shadow-xl tracking-widest">
              <span class="max-lg:hidden">CLICK TO EXPAND</span>
              <span class="lg:hidden">TAP TO EXPAND</span>
            </span>
          </div>
        </div>

        <div id="hero-slider-wrapper" class="w-full h-full absolute inset-0 transition-opacity duration-700 z-0">
          <div id="hero-slider" class="splide w-full h-full" aria-label="メインスライダー">
            <div class="splide__track w-full h-full">
              <ul class="splide__list w-full h-full">
                {displaySliders.map((slide: any, index: number) => {
                  const src = secureUrl(slide.featuredImage?.node?.sourceUrl) || placeholderImg;
                  const themeColor = slide.memberColor ? getValidColor(slide.memberColor) : globalBaseColor;
                  const bgColor = hexToRgba(themeColor, 0.75);
                  const borderColor = hexToRgba(themeColor, 0.5);
                  const textClass = getTextColorClasses(themeColor).main;

                  // 1枚目の画像のみ優先度を高め、それ以外は遅延読み込みにしてパフォーマンスを向上させます
                  const isPriority = index === 0;

                  return (
                    <li class="splide__slide w-full h-full relative">
                      <img src={src} alt="" class="js-main-bg absolute inset-0 w-full h-full object-cover opacity-70 blur-[20px] pointer-events-none" aria-hidden="true" referrerpolicy="no-referrer" />
                      <img 
                        src={src} 
                        alt={slide.title || 'Slide Image'} 
                        fetchpriority={isPriority ? "high" : "auto"} 
                        loading={isPriority ? "eager" : "lazy"} 
                        class="js-main-img absolute inset-0 w-full h-full object-contain z-10" 
                        referrerpolicy="no-referrer" 
                      />
                      
                      {slide.title && (
                        <div class="js-slide-title absolute top-20 right-4 lg:top-auto lg:bottom-10 lg:right-10 z-20 pointer-events-none text-right">
                          <h2 
                            class={`inline-block ${textClass} text-sm lg:text-2xl tracking-widest backdrop-blur-xl px-4 py-2 lg:px-8 lg:py-4 rounded-xl lg:rounded-2xl transition-all duration-500`}
                            style={`background-color: ${bgColor}; border: 1px solid ${borderColor}; box-shadow: 0 4px 16px rgba(0,0,0,0.6), 0 0 20px ${hexToRgba(themeColor, 0.6)};`}
                          >
                            {slide.title}
                          </h2>
                        </div>
                      )}
                    </li>
                  );
                })}
              </ul>
            </div>
          </div>
        </div>

        <div id="hero-static-wrapper" class="w-full h-full absolute inset-0 transition-opacity duration-700 opacity-0 hidden z-0">
          <img id="hero-static-bg" src="" alt="" class="absolute inset-0 w-full h-full object-cover opacity-70 blur-[20px] transition-opacity duration-500 pointer-events-none" aria-hidden="true" referrerpolicy="no-referrer" />
          <img id="hero-static-img" src="" alt="Selected Image" class="absolute inset-0 w-full h-full object-contain z-10 transition-all duration-700 ease-out" referrerpolicy="no-referrer" />
        </div>
        
        <div class="absolute bottom-0 left-0 w-full h-[35%] bg-gradient-to-t from-[#050505]/95 via-[#050505]/30 to-transparent pointer-events-none z-10" aria-hidden="true"></div>
        
        <header class="absolute bottom-6 lg:bottom-10 left-0 px-6 lg:px-10 w-full pointer-events-none z-10 flex items-end">
          <div>
            <!-- ここは set:html を使っているため、エンティティのままでも正常に表示されますが、念のためデコード済みの値を使用します -->
            <h1 id="hero-title" class="text-3xl lg:text-6xl font-light tracking-tighter text-transparent bg-clip-text bg-gradient-to-br from-white to-gray-500 [text-shadow:_0_4px_20px_rgb(0_0_0_/_80%)] leading-none transition-opacity duration-300" set:html={siteTitle}></h1>
            <div id="hero-bio" class="hidden mt-4 w-full pr-4 text-sm lg:text-base text-gray-200 font-light tracking-[0.1em] leading-relaxed [text-shadow:_0_2px_10px_rgb(0_0_0_/_100%)] opacity-0 transition-opacity duration-700"></div>
            <div id="hero-prompt" class="hidden mt-3 w-full pr-4 text-xs lg:text-sm text-gray-400 font-light tracking-wide leading-relaxed [text-shadow:_0_2px_10px_rgb(0_0_0_/_100%)] opacity-0 transition-opacity duration-700"></div>
          </div>
        </header>
      </section>

      <section class="w-full lg:w-[30%] h-auto lg:h-full relative flex flex-col bg-[#0A0A0C]/80 backdrop-blur-xl border-t lg:border-t-0 lg:border-l border-white/5 order-2" aria-label="コンテンツパネル" id="right-panel-wrapper">
        
        <div class="flex-1 lg:overflow-y-auto scroll-smooth p-5 lg:p-10 pb-32 lg:pb-[110px] hide-scrollbar transition-[padding] duration-300" id="right-panel">
          
          <article id="view-categories" class="view-section active" aria-labelledby="models-title">
            <h2 id="models-title" class="text-xl lg:text-2xl font-light mb-6 text-white border-b border-white/10 pb-4 tracking-tight">Models & Characters</h2>
            <div class="grid grid-cols-2 gap-4 lg:gap-5">
              {models.map((model: any) => {
                const latestArtworkImg = secureUrl(model.artworks?.nodes?.[0]?.featuredImage?.node?.sourceUrl);
                const avatarSrc = secureUrl(model.modelAvatar?.node?.sourceUrl) || placeholderImg;
                const displayImage = latestArtworkImg || avatarSrc;
                const modelColor = getValidColor(model.memberColor);
                
                const cardTextBgColor = hexToRgba(modelColor, 0.35);
                const cardTextBorderColor = hexToRgba(modelColor, 0.4);
                
                return (
                  <button 
                    class="js-nav-trigger group c-glass-card rounded-2xl overflow-hidden text-left outline-none flex flex-col h-full" 
                    data-target="view-works" 
                    data-model-id={model.id}
                    data-title={model.name} 
                    data-bio={model.modelBio || ''}
                    data-image={displayImage}
                    data-color={modelColor}
                    aria-label={`${model.name}の作品を見る`}
                  >
                    <figure class="m-0 flex flex-col h-full">
                      <div class="aspect-square overflow-hidden relative flex-shrink-0">
                        <img src={avatarSrc} loading="lazy" decoding="async" alt={model.name} class="w-full h-full object-cover object-top group-hover:scale-110 transition-transform duration-700 ease-out" referrerpolicy="no-referrer" />
                        <div class="absolute inset-0 opacity-0 group-hover:opacity-40 transition-opacity duration-700 pointer-events-none mix-blend-overlay" style={`background: linear-gradient(to top, ${modelColor}, transparent);`}></div>
                      </div>
                      <figcaption class="p-3 lg:p-4 flex-grow backdrop-blur-md transition-colors duration-300" style={`background-color: ${cardTextBgColor}; border-top: 1px solid ${cardTextBorderColor};`}>
                        <h3 class="font-medium text-white text-base tracking-wide drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)]">{model.name}</h3>
                        <p class="text-xs text-white/80 mt-1 font-light drop-shadow-[0_1px_2px_rgba(0,0,0,0.8)]">{model.artworks?.nodes?.length || 0} Works</p>
                      </figcaption>
                    </figure>
                  </button>
                )
              })}
            </div>
          </article>

          <article id="view-works" class="view-section hidden" aria-labelledby="works-title">
            <button class="js-back-btn text-gray-400 hover:text-white mb-6 flex items-center text-sm transition-colors group font-light tracking-widest uppercase" data-target="view-categories" aria-label="モデル一覧に戻る">
              <span class="mr-2 transform group-hover:-translate-x-1 transition-transform" aria-hidden="true">←</span> Back to Models

---
// src/components/SiteFooter.astro
interface Props {
  siteTitle: string;
  siteDescription: string;
  siteLogo?: string;
}

const { siteTitle, siteDescription, siteLogo } = Astro.props;

// アイコンが空だった場合のダミー画像
const defaultLogo = "https://images.unsplash.com/photo-1547891654-e66ed7ebb968?q=80&w=200&auto=format&fit=crop";
---
<aside class="w-full relative order-3 lg:absolute lg:bottom-0 lg:left-0 lg:w-[70%] lg:h-[90px] bg-[#050505] lg:bg-[#050505]/60 lg:backdrop-blur-xl border-t border-white/10 z-20 p-6 lg:px-10 flex flex-wrap lg:flex-nowrap items-center justify-between gap-4 transition-transform duration-500">
  
  <div class="flex items-center gap-6 lg:gap-8 shrink-0 min-w-0">
    <div class="flex items-center gap-4 shrink-0">
      <div class="w-12 h-12 rounded-full bg-gradient-to-tr from-[#F43F5E] to-purple-600 p-[2px]">
        {/* WPから渡されたURL（なければデフォルト）を表示 */}
        <img src={siteLogo || defaultLogo} alt={`${siteTitle} Logo`} class="w-full h-full rounded-full object-cover border-2 border-[#050505]" />
      </div>
      <div>
        <h3 class="text-white text-lg font-light tracking-tight leading-none" set:html={siteTitle}></h3>
        <p class="text-[#F43F5E] text-[10px] font-bold tracking-[0.2em] uppercase mt-1">AI Girls Gallery</p>
      </div>
    </div>
    
    <p class="text-gray-400 text-xs font-light hidden xl:block max-w-2xl truncate" set:html={siteDescription}></p>
  </div>

  <div class="flex items-center gap-3 shrink-0 ml-auto lg:ml-0">
    <!-- Instagram Link -->
    <a href="https://www.instagram.com/xx.ai.girls.miu0402/" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 px-4 py-2 bg-white/5 hover:bg-[#E1306C] text-white rounded-full transition-all duration-300 group border border-white/5 hover:border-transparent outline-none">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      <span class="font-light text-xs tracking-wide hidden sm:block">Instagram</span>
    </a>

    <!-- Patreon Link -->
    <a href="https://patreon.com/u73055670?utm_medium=unknown&utm_source=join_link&utm_campaign=creatorshare_creator&utm_content=copyLink" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 px-4 py-2 bg-white/5 hover:bg-[#FF424D] text-white rounded-full transition-all duration-300 group border border-white/5 hover:border-transparent outline-none">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 1080 1080"><path d="M1033.05,324.45c-0.19-137.9-107.59-250.92-233.6-291.7c-156.48-50.64-362.86-43.3-512.28,27.2 C106.07,145.41,49.18,332.61,47.06,519.31c-1.74,153.5,13.58,557.79,241.62,560.67c169.44,2.15,194.67-216.18,273.07-321.33 c55.78-74.81,127.6-95.94,216.01-117.82C929.71,603.22,1033.27,483.3,1033.05,324.45z"/></svg>
      <span class="font-light text-xs tracking-wide hidden sm:block">Patreon</span>
    </a>
  </div>
</aside>